{
  "hooks": {
    "session_start": {
      "command": "echo '--- Session started at '$(date '+%Y-%m-%d %H:%M')"
    }
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Edit",
      "Edit(*)",
      "Write",
      "Write(*)",
      "Read",
      "Read(*)",
      "TodoWrite",
      "Bash(*)"
    ]
  }
}
