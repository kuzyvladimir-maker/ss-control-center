# Veeqo
VEEQO_API_KEY=
VEEQO_BASE_URL=https://api.veeqo.com

# Sellbrite
SELLBRITE_ACCOUNT_TOKEN=
SELLBRITE_SECRET_KEY=
SELLBRITE_BASE_URL=https://api.sellbrite.com/v1

# Google Drive — used for shipping label PDF storage.
#
# Auth: OAuth2 refresh token on behalf of the folder owner
# (kuzy.vladimir@gmail.com). Service account does NOT work on personal
# Gmail Drive — service accounts have no storage quota and personal
# Gmail isn't a Workspace Shared Drive.
#
# See docs/wiki/google-drive-setup.md for the full one-time setup:
# Google Cloud Console → OAuth client → OAuth Playground for refresh token.
#
# When unset, labels still buy successfully — the modal links to the
# Veeqo-hosted label URL via /api/shipping/label-pdf as fallback (PDFs
# aren't pushed to Drive in that case).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_DRIVE_ROOT_FOLDER=
# Legacy alias for GOOGLE_DRIVE_ROOT_FOLDER. Kept for backward compat
# (existing deployments may have this name set); new deployments use
# GOOGLE_DRIVE_ROOT_FOLDER.
# GOOGLE_DRIVE_SHIPPING_LABELS_FOLDER_ID=

# (Google Sheets vars removed 2026-05-12 — SKU data migrated to the internal
# SkuShippingData Prisma table. See docs/wiki/sku-database-migration.md.)

# Telegram
TELEGRAM_BOT_TOKEN=
# Default chat (typically a personal DM). Used as fallback when no
# per-channel chat is configured below.
TELEGRAM_CHAT_ID=
# Account Health critical alerts. Set to a supergroup id (-100…) to route
# Account Health alerts to a group instead of the default DM.
TELEGRAM_ALERT_CHAT_ID=
# Optional. When TELEGRAM_ALERT_CHAT_ID points at a supergroup with topics
# enabled, set this to the topic (forum thread) id so alerts land in a
# specific topic instead of the General feed.
TELEGRAM_ALERT_THREAD_ID=
# Procurement priority pings. Falls back to TELEGRAM_CHAT_ID if unset.
TELEGRAM_PROCUREMENT_CHAT_ID=
# Walmart operational alerts (cancellation watchdog, ship-confirm summary,
# quantity-inquiry poll). Set to the "Рабочая Группа Salutem" supergroup id
# (-100…) to route them to the team group instead of the default DM. Falls
# back to TELEGRAM_CHAT_ID if unset.
TELEGRAM_WALMART_CHAT_ID=
# Optional forum-topic id inside TELEGRAM_WALMART_CHAT_ID.
TELEGRAM_WALMART_THREAD_ID=
#
# --- Notification kill-switches (Vladimir 2026-06-08) ---
# These Telegram streams are OFF by default to keep Jackie's DM clean. The
# underlying events still appear in the Control Center UI (and Account Health
# rows are still created). Set any flag to "true" on Vercel to restore its DM
# pings. See docs/wiki/telegram-notification-routing.md.
TELEGRAM_REPRICE_ENABLED=          # reprice-amazon cron summary (every 2h)
TELEGRAM_HEALTH_ALERTS_ENABLED=    # Account Health critical alerts (Amazon+Walmart)
TELEGRAM_SHIPPING_BUY_ENABLED=     # shipping label buy summary (manual action)
TELEGRAM_BUNDLE_PUBLISH_ENABLED=   # bundle publish success/first/failure pings

# AI Providers (at least one required; both recommended for automatic fallback)
# Primary — Claude (Anthropic). Better for structured JSON output.
ANTHROPIC_API_KEY=
# Fallback — OpenAI (gpt-4o). Used automatically if Claude fails or runs out of credits.
OPENAI_API_KEY=

# App
DATABASE_URL=file:./dev.db
NEXTAUTH_SECRET=

# Frozen Analytics — Origin location (Tampa, FL)
ORIGIN_LAT=27.9506
ORIGIN_LON=-82.4572
ORIGIN_CITY=Tampa
ORIGIN_STATE=FL

# Amazon SP-API (shared)
AMAZON_SP_MARKETPLACE_ID=ATVPDKIKX0DER
AMAZON_SP_ENDPOINT=https://sellingpartnerapi-na.amazon.com

