# Veeqo
VEEQO_API_KEY=
VEEQO_BASE_URL=https://api.veeqo.com

# Sellbrite
SELLBRITE_ACCOUNT_TOKEN=
SELLBRITE_SECRET_KEY=
SELLBRITE_BASE_URL=https://api.sellbrite.com/v1

# Google Drive — used for shipping label PDF storage
GOOGLE_DRIVE_ROOT_FOLDER=

# (Google Sheets vars removed 2026-05-12 — SKU data migrated to the internal
# SkuShippingData Prisma table. See docs/wiki/sku-database-migration.md.)

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AI Providers (at least one required; both recommended for automatic fallback)
# Primary — Claude (Anthropic). Better for structured JSON output.
ANTHROPIC_API_KEY=
# Fallback — OpenAI (gpt-4o). Used automatically if Claude fails or runs out of credits.
OPENAI_API_KEY=

# App
DATABASE_URL=file:./dev.db
NEXTAUTH_SECRET=

# Frozen Analytics — Origin location (Tampa, FL)
ORIGIN_LAT=27.9506
ORIGIN_LON=-82.4572
ORIGIN_CITY=Tampa
ORIGIN_STATE=FL

# Amazon SP-API (shared)
AMAZON_SP_MARKETPLACE_ID=ATVPDKIKX0DER
AMAZON_SP_ENDPOINT=https://sellingpartnerapi-na.amazon.com

# Amazon SP-API — per-store credentials (one LWA application per store)
