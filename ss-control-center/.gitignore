# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# but allow the no-secrets template
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# Active Listings Report dumps — fetched at runtime by
# scripts/fetch-active-listings.ts. Large + contains real Amazon
# listing data, regenerated on demand. Do not commit.
/data/imports/

# Immutable Walmart source captures can contain short-lived signed download
# URLs and raw Orders/Returns customer data. They stay local and must never be
# swept into version control; only sanitized seals/reconciliation may be shared.
/data/audits/walmart-source-captures/

# Throwaway test SQLite DBs (e.g. tmp-lqtest.db) created by diag scripts.
tmp-*.db
tmp-aplus-test/
