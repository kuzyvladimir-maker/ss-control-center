generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// Auth — users who can log in to the Control Center
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  displayName  String?
  // "admin" can manage invites and other users; "member" is a regular user.
  // The first registered user is automatically admin.
  role         String   @default("member")
  createdAt    DateTime @default(now())
}

// Single-use invitations issued by an admin. A new user can only register
// by visiting an invite link with a valid (unused, unexpired) token.
model Invite {
  id               String    @id @default(cuid())
  email            String // target email (lower-cased)
  token            String    @unique // unguessable URL-safe token
  role             String    @default("member") // role to assign on accept
  createdById      String // user.id of the admin who created it
  createdAt        DateTime  @default(now())
  expiresAt        DateTime // typically now() + 7 days
  acceptedAt       DateTime? // null while pending
  acceptedByUserId String? // user.id once accepted
  revokedAt        DateTime? // admin can revoke before use

  @@index([email])
}

model CsCase {
  id            String  @id @default(cuid())
  channel       String // Amazon | Walmart
  store         String?
  orderId       String?
  customerName  String?
  product       String?
  productType   String? // Frozen | Dry | Unknown
  category      String? // C1-C10
  categoryName  String?
  priority      String? // LOW | MEDIUM | HIGH | CRITICAL
  language      String? // English | Spanish
  branch        String? // A | B (for C3)
  branchName    String?
  response      String?
  action        String? // REPLACEMENT | REFUND | A2Z_GUARANTEE | ESCALATE | INFO | PHOTO_REQUEST
  urgency       String?
  internalNotes String?
  imageData     String? // base64 screenshot

  // Carrier delay detection (v1.2)
  carrierDelayDetected Boolean  @default(false)
  carrierBadge         String? // "Claims Protected" | "Late Delivery Risk" | "Unknown"
  shippedOnTime        Boolean?
  promisedEdd          String? // YYYY-MM-DD
  actualDelivery       String? // YYYY-MM-DD
  daysLate             Int?

  status     String    @default("open") // open | responded | resolved
  resolution String?
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model ShippingPlan {
  id        String             @id @default(cuid())
  date      String // YYYY-MM-DD
  status    String             @default("draft") // draft | approved | completed
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  items     ShippingPlanItem[]
}

model ShippingPlanItem {
  id               String       @id @default(cuid())
  planId           String
  plan             ShippingPlan @relation(fields: [planId], references: [id])
  orderNumber      String
  orderId          String // Veeqo order ID
  channel          String
  // Normalised marketplace bucket — "Amazon", "Walmart", "eBay", etc.
  // Drives the Drive folder path. Falls back to `channel` for legacy
  // rows created before this column existed.
  channelKind      String?
  product          String
  sku              String?
  qty              Int          @default(1)
  productType      String // Frozen | Dry
  weight           Float?
  boxSize          String?
  budgetMax        Float?
  carrier          String?
  service          String?
  price            Float?
  edd              String? // EDD date
  deliveryBy       String? // Delivery By date
  // Per-order dual-date model (MASTER_PROMPT v3.3 §0.1).
  //   labelDate         — what Amazon sees on the label; drives Late
  //                       Shipment Rate. Defaults to today; only
  //                       pushed to next business day when shipBy >
  //                       today AND past 3 PM ET cutoff.
  //   physicalShipDate  — when warehouse hands the package to the
  //                       carrier. Same as labelDate for normal flow;
  //                       pushed to next Monday when Frozen Ship Date
  //                       Trick fires.
  // `actualShipDay` is kept as an alias for physicalShipDate during
  // the migration so existing rows don't lose data. New writes set
  // both to the same value; legacy column drops once every reader
  // uses physicalShipDate.
  labelDate        String? // Date Amazon sees on the label
  physicalShipDate String? // When warehouse hands package to carrier
  actualShipDay    String? // Legacy alias for physicalShipDate
  notes            String?
  status           String       @default("pending") // pending | approved | bought | error | stop
  trackingNumber   String?
  labelPdfUrl      String?
  allocationId     String?
  carrierId        String?
  remoteShipmentId String?
  serviceType      String?
  subCarrierId     String?
  serviceCarrier   String?
  totalNetCharge   String?
  baseRate         String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([planId])
  @@index([orderId])
}

model Store {
  id         String   @id @default(cuid())
  name       String
  channel    String // Amazon | Walmart
  signature  String   @default("") // Name used in CS responses
  active     Boolean  @default(true)
  // Bridge to the underlying order/transaction tables. Amazon stores use a
  // 1..5 integer (matches AmazonOrder.storeIndex / AtozzClaim.storeIndex /
  // BuyerMessage.storeIndex). Walmart stores use the Marketplace Seller ID.
  storeIndex Int?
  sellerId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model ProductTypeOverride {
  id             String   @id @default(cuid())
  productId      Int      @unique // Veeqo product ID
  type           String // "Frozen" | "Dry"
  // Who/what set the type — manual classification by the operator or AI
  // (Claude) suggestion that was confirmed in the Shipping Labels UI.
  source         String   @default("manual") // "manual" | "ai"
  aiConfidence   Float?
  aiReasoning    String?
  // Veeqo round-trip: the canonical tag lives on the Veeqo product too so
  // legacy paths keep working. syncedToVeeqo is true after a successful
  // setProductTag; veeqoSyncError records the last failure for retry.
  syncedToVeeqo  Boolean  @default(false)
  veeqoSyncError String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Frozen Delivery Analytics
model FrozenIncident {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Link to CS case
  csCaseId String?

  // Order data
  orderId        String
  amazonOrderId  String?
  trackingNumber String?

  // Product
  sku         String
  productName String
  boxSize     String? // XS/S/M/L/XL
  weightLbs   Float?

  // Shipping
  carrier              String // ups / fedex / usps
  service              String // "2nd Day Air" / "Ground" / etc.
  shipDate             String // YYYY-MM-DD
  promisedEdd          String? // YYYY-MM-DD
  actualDelivery       String? // YYYY-MM-DD
  daysInTransit        Int?
  daysLate             Int?
  claimsProtectedBadge Boolean?
  labelCost            Float?

  // Destination
  destZip   String?
  destCity  String?
  destState String?
  destLat   Float?
  destLon   Float?

  // Weather — origin (Tampa, FL)
  originTempF       Float?
  originFeelsLikeF  Float?
  originTempHighF   Float?
  originWeatherDesc String?

  // Weather — destination
  destTempF       Float?
  destFeelsLikeF  Float?
  destTempHighF   Float?
  destWeatherDesc String?

  // Outcome
  outcome            String  @default("thawed") // thawed | unclear | ok
  customerComplained Boolean @default(true)
  resolution         String? // a2z_guarantee / replacement / refund
  notes              String?

  // Frozen Analytics v2.0 — back-link from incident to the proactive risk
  // alert (if any) that predicted this incident. Set by the learning loop in
  // collectFrozenIncidentData() so the Patterns dashboard can compute
  // detection rate (true positives = incidents that had a linked alert).
  linkedAlertId String?

  @@index([linkedAlertId])
}

model SkuRiskProfile {
  id        String   @id @default(cuid())
  updatedAt DateTime @updatedAt

  sku         String @unique
  productName String

  totalIncidents Int    @default(0)
  thawedCount    Int    @default(0)
  thawRate       Float?

  avgDaysInTransit Float?
  avgOriginTempF   Float?
  avgDestTempF     Float?

  mostCommonCarrier String?
  mostCommonService String?

  riskScore Int    @default(0) // 0-100
  riskLevel String @default("unknown") // low / medium / high / critical

  lastIncidentDate String?
}

// Shipping Adjustments Monitor
model ShippingAdjustment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  externalId String @unique // from Amazon/Walmart API (dedup)
  channel    String // Amazon | Walmart

  orderId        String
  amazonOrderId  String?
  walmartOrderId String?

  adjustmentDate   String // YYYY-MM-DD
  adjustmentType   String // WeightAdjustment | DIMadjustment | CarrierAdjustment
  adjustmentAmount Float // negative USD
  adjustmentReason String?

  sku               String?
  productName       String?
  carrier           String?
  service           String?
  declaredWeightLbs Float?
  declaredDimL      Float?
  declaredDimW      Float?
  declaredDimH      Float?
  originalLabelCost Float?

  adjustedWeightLbs Float?
  adjustedDimL      Float?
  adjustedDimW      Float?
  adjustedDimH      Float?

  reviewed     Boolean @default(false)
  skuDataFixed Boolean @default(false)
  notes        String?
}

model SkuAdjustmentProfile {
  id        String   @id @default(cuid())
  updatedAt DateTime @updatedAt

  sku         String  @unique
  productName String?

  totalAdjustments    Int    @default(0)
  totalAmountLost     Float  @default(0)
  avgAdjustmentAmount Float?

  mostCommonType   String? // WeightAdjustment | DIMadjustment
  needsSkuDbUpdate Boolean @default(false)
  suggestedWeight  Float?

  lastAdjustmentDate String?
  channel            String? // where more frequent
}

// A-to-Z & Chargeback Claims
model AtozzClaim {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  amazonOrderId String
  claimType     String // A_TO_Z | CHARGEBACK
  claimReason   String? // INR | SNAD | Defective | Fraud
  amount        Float?
  storeIndex    Int     @default(1)
  storeName     String?
  // Full order context pulled from SP-API on enrichment
  customerName  String?
  product       String?
  orderDate     String?
  orderTotal    Float?
  claimText     String? // The buyer's actual claim/complaint text

  detectedAt        DateTime @default(now())
  deadline          String? // YYYY-MM-DD
  daysUntilDeadline Int?

  gmailMessageId String?

  // Evidence
  trackingNumber       String?
  carrier              String?
  shipDate             String?
  firstScanDate        String?
  deliveredDate        String?
  shippedOnTime        Boolean?
  claimsProtectedBadge Boolean?
  evidenceSummary      String? // JSON

  // Strategy & Response
  strategyType       String? // BUY_SHIPPING_PROTECTION | PROOF_OF_DELIVERY | INR_DEFENSE | CARRIER_DELAY_DEFENSE | MANUAL_REVIEW
  strategyConfidence String? // HIGH | MEDIUM | LOW
  generatedResponse  String?
  editedResponse     String?

  // Status: NEW → EVIDENCE_GATHERED → RESPONSE_READY → SUBMITTED → DECIDED → APPEALED → CLOSED
  status String @default("NEW")

  // Amazon decision
  amazonDecision String? // IN_OUR_FAVOR | AGAINST_US | AMAZON_FUNDED
  decisionDate   String?
  amountCharged  Float?
  amountSaved    Float?

  // Appeal
  appealSubmitted Boolean @default(false)
  appealText      String?
  appealDecision  String?

  vladimirNotes String?
  csCaseId      String?
}

// Feedback Manager
model SellerFeedback {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  amazonFeedbackId String  @unique
  orderId          String
  amazonOrderId    String?
  rating           Int // 1-5
  comments         String?
  feedbackDate     String // YYYY-MM-DD

  store   String?
  channel String  @default("Amazon")

  // AI classification
  removable         Boolean?
  removalCategory   String? // PRODUCT_REVIEW | CARRIER_DELAY | OBSCENE | PERSONAL_INFO | PROMOTIONAL | PRICING_ONLY
  removalConfidence String? // HIGH | MEDIUM | LOW
  suggestedAction   String? // REQUEST_REMOVAL | CONTACT_BUYER | RESPOND_PUBLICLY | MONITOR
  aiReasoning       String?

  removalRequestText String?
  publicResponse     String? // Claude-generated public reply for non-removable negative/positive feedback

  // Status: NEW → ANALYZED → REMOVAL_SUBMITTED → REMOVED | DENIED | CONTACT_SENT | CLOSED
  status String @default("NEW")

  removalSubmittedAt DateTime?
  removalDecision    String? // REMOVED | DENIED
  removalDecisionAt  DateTime?

  buyerContactSent   Boolean   @default(false)
  buyerContactText   String?
  buyerContactSentAt DateTime?

  csCaseId      String?
  vladimirNotes String?
}

model ProductReview {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  asin       String
  reviewId   String  @unique
  rating     Int // 1-5
  title      String?
  body       String?
  reviewDate String
  verified   Boolean @default(false)

  store String?

  responseGenerated   String?
  responseSubmitted   Boolean   @default(false)
  responseSubmittedAt DateTime?

  vladimirNotes String?
}

// Account Health Monitor
model AccountHealthSnapshot {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  storeId   String
  storeName String?
  sellerId  String?
  status    String   @default("pending") // healthy | warning | critical | error | pending

  // ODR (60 days)
  orderDefectRate       Float?
  odrOrders60d          Int? // total orders in 60d
  negativeFeedbackCount Int?
  negativeFeedbackRate  Float?
  atozClaimsCount       Int?
  atozClaimsRate        Float?
  chargebackCount       Int?
  chargebackRate        Float?

  // Late Shipment Rate — 10-day window
  lateShipmentRate10d Float?
  lsr10dLate          Int? // late orders
  lsr10dTotal         Int? // total orders

  // Late Shipment Rate — 30-day window
  lateShipmentRate30d Float?
  lsr30dLate          Int?
  lsr30dTotal         Int?

  // Pre-fulfillment Cancel Rate (7 days)
  preFulfillmentCancelRate Float?
  cancelCancelled          Int?
  cancelTotal              Int?

  // Valid Tracking Rate (30 days)
  validTrackingRate Float?
  vtrTracked        Int?
  vtrTotal          Int?

  // On-Time Delivery Rate (14 days)
  onTimeDeliveryRate Float?
  otdrOnTime         Int?
  otdrTotal          Int?

  // Sync
  syncStatus String    @default("pending") // pending | syncing | done | error
  syncError  String?
  syncedAt   DateTime?

  alertCount    Int     @default(0)
  criticalCount Int     @default(0)
  alertsJson    String?

  // ── Account Health v2 additions ─────────────────────────────────────────

  // Aggregate AHR (0..1000) and zone label fetched alongside the ODR/LSR
  // metrics. May be null when SP-API Selling Partner Insights role isn't
  // approved yet — see src/lib/amazon-sp-api/account-health-rating.ts.
  accountHealthRating       Int?
  accountHealthRatingStatus String? // AT_RISK_OF_DEACTIVATION | AT_RISK | GOOD

  // ODR breakdown by fulfillment channel
  odrSellerFulfilled         Float?
  odrSellerFulfilledOrders   Int?
  odrFulfilledByAmazon       Float?
  odrFulfilledByAmazonOrders Int?

  // Customer-service sub-metrics by fulfillment channel
  negativeFeedbackSF  Float?
  negativeFeedbackFBA Float?
  atozClaimsRateSF    Float?
  atozClaimsRateFBA   Float?
  chargebackRateSF    Float?
  chargebackRateFBA   Float?

  policyCategories PolicyViolationCategory[]

  @@index([storeId, createdAt])
}

// ─── Account Health v2: Policy Compliance ──────────────────────────────────
// One row per category per snapshot (10 fixed categories). Drill-down to
// individual listings lives in PolicyViolationDetail.
model PolicyViolationCategory {
  id         String                @id @default(cuid())
  snapshotId String
  snapshot   AccountHealthSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  category    String // SUSPECTED_IP | RECEIVED_IP_COMPLAINTS | PRODUCT_AUTHENTICITY | PRODUCT_CONDITION | FOOD_SAFETY | LISTING_POLICY | RESTRICTED_PRODUCT | CUSTOMER_REVIEWS_POLICY | OTHER_POLICY | REGULATORY_COMPLIANCE
  displayName String
  count       Int      @default(0)
  status      String // OK | WARNING | CRITICAL
  detectedAt  DateTime @default(now())

  details PolicyViolationDetail[]

  @@index([snapshotId])
  @@index([category])
}

model PolicyViolationDetail {
  id         String                  @id @default(cuid())
  categoryId String
  category   PolicyViolationCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  asin              String?
  sku               String?
  listingTitle      String?
  violationType     String
  severity          String // CRITICAL | HIGH | MEDIUM | LOW
  message           String
  reportedAt        DateTime
  resolvedAt        DateTime?
  status            String    @default("OPEN") // OPEN | RESOLVED | IN_REVIEW
  amazonReferenceId String?

  @@index([categoryId])
  @@index([asin])
  @@index([status])
}

model AccountAlert {
  id         String    @id @default(cuid())
  createdAt  DateTime  @default(now())
  storeId    String
  storeName  String
  level      String // WARNING | CRITICAL
  metric     String
  value      Float
  threshold  Float
  message    String
  resolved   Boolean   @default(false)
  resolvedAt DateTime?
}

model ReportSyncJob {
  id               String    @id @default(cuid())
  createdAt        DateTime  @default(now())
  storeId          String
  reportType       String
  amazonReportId   String?
  amazonDocumentId String?
  status           String    @default("requested") // requested | processing | downloading | done | error
  error            String?
  completedAt      DateTime?
}

// Amazon Orders (synced from SP-API)
model AmazonOrder {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  amazonOrderId  String    @unique
  storeIndex     Int
  status         String // Pending | Unshipped | Shipped | Canceled
  purchaseDate   DateTime
  lastUpdateDate DateTime?
  orderTotal     Float     @default(0)
  currency       String    @default("USD")

  buyerName  String?
  buyerEmail String?

  shipCity    String?
  shipState   String?
  shipZip     String?
  shipCountry String?

  latestShipDate     DateTime?
  latestDeliveryDate DateTime?
  numberOfItems      Int       @default(0)
  fulfillmentChannel String?
  salesChannel       String?
  cancellationReason String?

  @@index([storeIndex, status])
  @@index([purchaseDate])
}

// Customer Hub — Buyer Messages
model BuyerMessage {
  id         String    @id @default(cuid())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  // When Amazon actually delivered the message to us (from email Date header).
  // Used for the 24-hour Amazon response deadline — createdAt is when we
  // synced it into our DB, which can be hours/days later.
  receivedAt DateTime?

  gmailMessageId String? @unique
  gmailThreadId  String?

  channel    String  @default("Amazon") // Amazon | Walmart
  source     String  @default("gmail") // gmail | screenshot
  storeIndex Int
  storeName  String
  storeEmail String?

  customerName  String?
  customerEmail String?
  language      String  @default("English")

  amazonOrderId   String?
  // Walmart-specific identifiers — populated when channel='Walmart' and
  // the source is the direct Marketplace API (not a screenshot upload).
  walmartOrderId  String?
  walmartReturnId String?
  orderDate       String?
  orderTotal      Float?

  product     String?
  asin        String?
  productType String?
  quantity    Int?

  carrier                  String?
  service                  String?
  trackingNumber           String?
  shipDate                 String?
  promisedEdd              String?
  actualDelivery           String?
  trackingStatus           String?
  daysInTransit            Int?
  daysLate                 Int?
  // Shipping service tracking — detects mismatches between what the
  // customer paid for (Amazon order's ShipmentServiceLevelCategory) and
  // what we actually shipped via Veeqo. Drives T21 classification.
  requestedShippingService String?
  actualShippingService    String?
  shippingMismatch         Boolean  @default(false)
  carrierEstimatedDelivery String?
  // JSON array of carrier tracking events from the carrier's direct API
  // (currently UPS; FedEx/USPS to follow). Shape:
  //   [{date, time, description, status, location}, ...]
  // Fed into the analyzer prompt so the model sees the full carrier
  // history instead of just the latest summary field.
  trackingEvents           String?
  boughtThroughVeeqo       Boolean  @default(false)
  claimsProtected          Boolean  @default(false)
  shippedOnTime            Boolean?

  direction           String  @default("incoming")
  customerMessage     String?
  // Russian translation cache. customerMessageRu is populated when the
  // message is first synced; suggestedResponseRu + editedResponseRu are
  // populated whenever their EN counterparts change. Used by the bilingual
  // UI so Vladimir can read/edit in RU without copy-pasting to a translator.
  customerMessageRu   String?
  suggestedResponseRu String?
  editedResponseRu    String?

  problemType     String?
  problemTypeName String?
  riskLevel       String?
  category        String?
  categoryName    String?
  priority        String?
  action          String?
  secondaryAction String?
  whoShouldPay    String?
  internalAction  String?
  foodSafetyRisk  Boolean @default(false)
  atozRisk        String?

  suggestedResponse String?
  editedResponse    String?
  responseSentAt    DateTime?
  responseSentVia   String?

  // Structured supplier-reorder note generated by the analyzer when
  // action=replacement. Format: "{product} × {qty} | reason: {short} |
  // ship to: {address hint}". Surfaced in MessageDetail as a prominent
  // banner so the operator can clone the order in Veeqo for the
  // replacement label run. Phase 2 will auto-clone via Veeqo API.
  supplierReorderNote String?

  status     String  @default("NEW")
  resolution String?

  frozenIncidentId String?
  vladimirNotes    String?
  imageData        String?

  // JSON blob of the last FactCheckResult from message-analyzer.ts. Stored
  // so the UI can render warnings + confidence without recomputing on every
  // render. Shape: { passed, confidence, mismatches: [{field, inResponse,
  // actual, severity}] }
  factCheckJson String?

  // AI reasoning + audit trail. Holds the internal "why this decision"
  // explanation from the analyzer, plus any [AUTO-FIXED: …] markers
  // appended by the validator. Used by the UI to surface the auto-fix
  // banner and (eventually) for debugging.
  reasoning String?

  @@index([amazonOrderId])
  @@index([storeIndex, status])
}

// Sync log
model SyncLog {
  id          String    @id @default(cuid())
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  jobName     String // orders | finances | feedback | health | claims
  storeIndex  Int?
  status      String  @default("running") // running | done | error
  itemsSynced Int     @default(0)
  error       String?
}

// Customer Hub — Knowledge Base
// Stores resolved customer-support cases so the Decision Engine can find
// similar past situations before generating a new response. Seeded with
// canonical scenarios (e.g. T21 shipping mismatch) and extended either
// manually from the Save-to-KB button in MessageDetail or automatically
// from high-confidence resolved cases.
model KnowledgeBaseEntry {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Кейс
  problemType  String // T1-T21
  scenario     String // краткое описание ситуации
  customerSaid String // что написал клиент (ключевые фразы)

  // Контекст
  trackingStatus   String?
  shippingMismatch Boolean @default(false)
  productType      String? // Frozen | Dry

  // Решение
  correctAction   String // replacement | partial_refund | full_refund | redirect_amazon | etc.
  correctResponse String // текст правильного ответа
  reasoning       String // почему это решение правильное
  whoShouldPay    String? // us | amazon | carrier

  // Результат
  outcome           String? // positive | negative | neutral
  customerSatisfied Boolean?
  atozFiled         Boolean  @default(false)

  // Метаданные
  source  String  @default("manual") // manual | auto_from_resolved_case
  tags    String? // comma-separated tags
  channel String  @default("Amazon") // Amazon | Walmart — different rulebooks

  @@index([problemType])
}

// ----------------------------------------------------------------------------
// Walmart Marketplace API — direct integration models
// ----------------------------------------------------------------------------

// Walmart orders synced from /v3/orders. Mirrors the AmazonOrder pattern.
model WalmartOrder {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrderId String  @unique // Walmart PO ID — primary key in their API
  customerOrderId String // human-friendly order number
  customerEmailId String?
  storeIndex      Int     @default(1)

  status                String // Created | Acknowledged | Shipped | Delivered | Cancelled
  shipNodeType          String? // SellerFulfilled | WFSFulfilled | 3PLFulfilled
  orderType             String?
  orderDate             DateTime
  estimatedShipDate     DateTime?
  estimatedDeliveryDate DateTime?

  orderTotal Float  @default(0)
  currency   String @default("USD")

  shipCity    String?
  shipState   String?
  shipZip     String?
  shipCountry String?

  numberOfItems Int    @default(0)
  // JSON dump of the full order payload — preserves every field we don't
  // model explicitly so reanalysis / debugging never has to re-fetch.
  rawData       String

  @@index([storeIndex, status])
  @@index([orderDate])
  @@index([customerOrderId])
}

// Per-row reconciliation report transactions. Each row is one money event.
model WalmartReconTransaction {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  storeIndex                 Int      @default(1)
  reportDate                 DateTime // settlement date the row came from
  transactionPostedTimestamp DateTime
  transactionType            String // Sales | Refunds | Adjustments | Fees
  transactionDescription     String?

  purchaseOrderId String?
  customerOrderId String?
  sku             String?
  productName     String?
  quantity        Int?
  amount          Float
  feeType         String?

  rawData String

  // Dedup compound key: same posted-timestamp + PO + type + amount = same row.
  @@unique([transactionPostedTimestamp, purchaseOrderId, transactionType, amount], name: "walmart_recon_dedup")
  @@index([reportDate])
  @@index([transactionType])
  @@index([storeIndex, reportDate])
}

// Snapshot of a Walmart Seller Performance metric at a point in time.
// We keep history so trends can be plotted over weeks/months. NOTE: this
// model is per-metric (one row per metric per sync) — the Account Health v2
// UI reads the latest row of each metric and aggregates at query time, so
// nothing here is denormalized.
model WalmartPerformanceSnapshot {
  id         String   @id @default(cuid())
  capturedAt DateTime @default(now())

  storeIndex Int     @default(1)
  windowDays Int // 14 | 30 | 60 | 90
  metric     String // onTimeDelivery | validTrackingRate | ...
  value      Float // percent or ratio
  threshold  Float? // Walmart's healthy threshold for this metric
  isHealthy  Boolean

  // Status bucket for the UI (GOOD | MONITOR | URGENT). Added in v2 so the
  // sync layer doesn't have to re-derive it from value+threshold on every
  // read, and so the alerts engine can filter cheaply.
  status String?

  rawData String

  @@index([storeIndex, metric, capturedAt])
}

// ─── Account Health v2: Walmart Item Compliance ────────────────────────────
// Per-item compliance issue. Pulled from the Walmart Items API filtered by
// lifecycleStatus (TROUBLED / BLOCKED / PUBLISHED_WITH_ERRORS / etc).
model WalmartItemCompliance {
  id         String   @id @default(cuid())
  storeIndex Int      @default(1)
  capturedAt DateTime @default(now())

  itemId       String
  sku          String?
  title        String?
  issueType    String // TROUBLED_LISTING | BLOCKED | PUBLISHED_WITH_ERRORS | STAGE | SYSTEM_PROBLEM
  issueDetails String?
  severity     String // URGENT | MONITOR | INFO
  status       String    @default("OPEN") // OPEN | RESOLVED
  reportedAt   DateTime
  resolvedAt   DateTime?

  // Dedup by (item + issueType) so a re-sync updates the existing row
  // instead of duplicating.
  @@unique([itemId, issueType], name: "walmart_item_compliance_dedup")
  @@index([storeIndex])
  @@index([status])
}

// ─── Account Health v2: Critical Alerts ────────────────────────────────────
// Generated by src/lib/account-health/critical-alert-evaluator.ts whenever
// a fresh snapshot breaches a threshold defined in alert-rules.ts. Each row
// is one detected breach — UI lists them as a bell-icon feed, and Telegram
// delivery is tracked here too.
model CriticalAlert {
  id      String @id @default(cuid())
  storeId String

  channel   String // Amazon | Walmart
  alertType String // metric name from alert-rules.ts
  severity  String // CRITICAL | HIGH | WARNING

  metricName      String
  metricValue     String
  metricThreshold String

  title     String
  message   String
  actionUrl String?

  detectedAt DateTime @default(now())

  // Telegram delivery
  telegramSent      Boolean   @default(false)
  telegramSentAt    DateTime?
  telegramMessageId String?

  // UI acknowledgment
  acknowledged   Boolean   @default(false)
  acknowledgedAt DateTime?
  acknowledgedBy String?

  // Resolution
  resolvedAt DateTime?

  @@index([storeId])
  @@index([acknowledged])
  @@index([detectedAt])
  @@index([severity])
}

// Procurement: where to buy each SKU (store priority).
// Populated/edited in later phases — Phase 1 only declares the schema.
model SKUStorePriority {
  id        String   @id @default(cuid())
  sku       String
  storeName String
  priority  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sku, storeName])
  @@index([sku])
}

// Procurement: action queue for offline mode (Phase 6).
model ProcurementSyncQueue {
  id           String    @id @default(cuid())
  lineItemId   String
  orderId      String
  action       String
  payload      Json
  status       String    @default("pending")
  createdAt    DateTime  @default(now())
  syncedAt     DateTime?
  errorMessage String?

  @@index([status])
}

// Procurement: log of priority-order notifications (Phase 7).
model ProcurementNotificationLog {
  id         String   @id @default(cuid())
  orderId    String   @unique
  notifiedAt DateTime @default(now())

  @@index([notifiedAt])
}

// Packing profile for multi-item / multi-qty orders. The default Shipping
// Labels algorithm looks up box+weight in SkuShippingData by SKU, which only
// works for single-line, single-quantity orders. When an order contains
// multiple lines (or qty > 1) we need an explicit profile. This table is
// populated by the operator the first time such an order appears; subsequent
// orders with the same composition (same SKUs + quantities) reuse it
// automatically.
model PackingProfile {
  id          String   @id @default(cuid())

  // Deterministic signature of the composition:
  // "SKU1:QTY1|SKU2:QTY2|..." sorted lexicographically by SKU.
  // Example: "T4-Y0G0-ZHII:2|XM-A131-UXNC:1".
  signature   String   @unique
  description String?

  boxSize     String
  weight      Float // lbs, UPS/USPS/FedEx standard
  weightFedex Float?  // lbs, FedEx One Rate (falls back to weight × 1.25 when null)

  itemCount   Int      @default(1)
  totalQty    Int      @default(1)
  usedCount   Int      @default(0)
  lastUsedAt  DateTime?

  // Phase 2 hook: semantic-similarity matching across "looks like" orders.
  // Stored as JSON-encoded float array. Not consumed today.
  productEmbedding String?

  source      String   @default("manual") // "manual" | "ai_suggested"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([signature])
}

// SKU Shipping Database — replaces the Google Sheets "SKU Shipping Database
// v2" that the Shipping Labels module used to read. Migrated 2026-05-12.
// Source of truth for: weight, dimensions, category (Frozen/Dry), and the
// special FedEx One Rate weight (which is intentionally separate from the
// regular weight because One Rate billable weight ≈ H × 1.25).
// See docs/wiki/sku-database-migration.md for the migration story.
model SkuShippingData {
  id           String   @id @default(cuid())
  sku          String   @unique
  productTitle String?
  marketplace  String? // Amazon | Walmart | Both | Other
  category     String? // Frozen | Dry
  length       Float? // inches
  width        Float? // inches
  height       Float? // inches
  weight       Float? // lbs — UPS / USPS / FedEx standard
  weightFedex  Float? // lbs — FedEx One Rate only
  sampleCount  Int      @default(0)
  notes        String?
  // Provenance: google_sheets_migration | manual | veeqo_history
  source       String   @default("manual")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Frozen Analytics v2.0 — Proactive Risk Prediction ─────────────────────
// Nightly pipeline fetches Veeqo orders that will ship in the next 1-3 days,
// pulls Open-Meteo forecast for Tampa (origin) and the destination ZIP, runs
// the rule engine, and writes one row per (orderId, shipDate) pair. Status
// transitions: pending → applied | ignored | resolved. The learning loop
// fills resultedInComplaint / linkedIncidentId after the order delivers and
// CS either logs a thaw incident or doesn't.
model FrozenRiskAlert {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Order identification
  orderId      String // Veeqo order number (e.g. "113-4567890")
  veeqoOrderId String? // Internal Veeqo ID
  storeIndex   Int? // 1-5 for Amazon stores when resolvable
  storeName    String? // "Salutem Solutions" etc.
  channel      String  @default("Amazon") // Amazon | Walmart

  // Product
  sku         String
  productName String?
  asin        String?

  // Shipping plan (at time of alert generation)
  shipDate       String // YYYY-MM-DD
  edd            String? // YYYY-MM-DD expected delivery date
  transitDays    Int?
  plannedCarrier String? // ups | fedex | usps
  plannedService String? // "Ground" | "2nd Day Air" etc.

  // Destination
  destZip   String
  destCity  String?
  destState String?
  destLat   Float?
  destLon   Float?

  // Weather — Tampa (origin) on ship_date
  originTempF       Float? // forecast mean (we store the daily max here for risk eval)
  originFeelsLikeF  Float?
  originTempMaxF    Float?
  originNormalF     Float? // 30-year average
  originAnomalyF    Float? // origin - normal
  originWeatherDesc String?

  // Weather — Destination on EDD
  destTempF       Float?
  destFeelsLikeF  Float?
  destTempMaxF    Float?
  destNormalF     Float?
  destAnomalyF    Float?
  destWeatherDesc String?

  // Risk assessment
  riskLevel       String // ok | low | medium | high | critical
  riskScore       Int // 0-100
  triggeredRules  String // JSON array: ["R3", "M1"]
  recommendations String // JSON array of strings

  // User action
  status                 String    @default("pending") // pending | applied | ignored | resolved
  appliedAt              DateTime?
  appliedBy              String?
  userNotes              String?
  shippingChoiceFollowed Boolean? // Did user follow recommended carrier/service?

  // Learning loop (filled after delivery)
  resultedInComplaint Boolean? // Set when linked incident is found, or to false after lookback window passes
  linkedIncidentId    String? // FrozenIncident.id if complaint came

  @@unique([orderId, shipDate])
  @@index([riskLevel, status])
  @@index([shipDate])
  @@index([sku])
  @@index([storeIndex])
}

// Conditions and outcomes are stored as JSON strings so a future Phase-4 UI
// rule editor can mutate them without schema changes. See
// src/lib/frozen-analytics/rules-engine.ts for the runtime shape.
model FrozenRule {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ruleCode    String @unique // "R1", "R2", ..., "M1", "M2", ...
  ruleType    String // "base" | "modifier"
  description String

  // Conditions (JSON for flexibility)
  conditions String // {"originMin":85,"originMax":90,"destMin":null,...}

  // Outcome
  riskLevel      String? // ok|low|medium|high|critical (for base rules)
  modifier       Int? // +1, +2 (for modifier rules)
  recommendation String? // text template

  enabled  Boolean @default(true)
  priority Int     @default(100) // lower = applied first
}

// ────────────────────────────────────────────────────────────────────
// BUNDLE FACTORY (Phase 1) — see docs/BUNDLE_FACTORY_DATA_MODEL.md
// ────────────────────────────────────────────────────────────────────
//
// All "enum-like" fields are stored as String because SQLite + Prisma do
// not support native enum types. Allowed values are documented inline and
// also exported as TypeScript const-unions from
// `src/lib/bundle-factory/enums.ts` so application code stays type-safe.
//
// Enum reference:
//   LifecycleState       = DRAFT | RESEARCHED | VARIATION_SELECTED | GENERATED |
//                          APPROVED | QUEUED | SUBMITTED | PROCESSING | LIVE |
//                          ERROR | SUSPENDED | SUNSET_REQUESTED | ARCHIVED
//   ProductCategory      = FROZEN_GROCERY | REFRIGERATED | SHELF_STABLE |
//                          PET_FOOD | HEALTH_BEAUTY | BABY | OTHER
//   SalesChannel         = AMAZON_PERSONAL | AMAZON_SALUTEM | AMAZON_AMZCOM |
//                          AMAZON_SIRIUS | AMAZON_RETAILER | WALMART | EBAY |
//                          TIKTOK_1 | TIKTOK_2
//   CompositionType      = SINGLE_FLAVOR | MIXED_FLAVOR | USE_CASE |
//                          HOLIDAY_THEMED | CROSS_BRAND
//   PipelineStage        = BRIEF | RESEARCH | VARIATION_MATRIX |
//                          CONTENT_GENERATION | IMAGE_GENERATION |
//                          VALIDATION | DISTRIBUTION
//   StageStatus          = PENDING | IN_PROGRESS | COMPLETED | FAILED | SKIPPED
//   ErrorCategory        = MISSING_REQUIRED_ATTRIBUTE | TITLE_LENGTH_EXCEEDED |
//                          BANNED_WORD | IMAGE_URL_INACCESSIBLE | DUPLICATE_GTIN |
//                          INVALID_BROWSE_NODE | POLICY_VIOLATION_BRAND |
//                          POLICY_VIOLATION_BUNDLE | COMPLIANCE_GROCERY |
//                          COMPLIANCE_FROZEN | UNKNOWN
//   UPCStatus            = AVAILABLE | RESERVED | ASSIGNED | RETIRED | INVALID
//   StoreType            = SUPERCENTER | NEIGHBORHOOD_MARKET | WAREHOUSE_CLUB |
//                          STANDARD_GROCERY | DEPARTMENT_STORE | DISCOUNT_GROCERY |
//                          PREMIUM_GROCERY | SPECIALTY
//   StoreTier            = TIER_1 | TIER_2 | TIER_3 | TIER_4 | TIER_5
//   GTINExemptionStatus  = NOT_REQUESTED | PENDING_APPLICATION | UNDER_REVIEW |
//                          APPROVED | DENIED

// MasterBundle — the canonical "recipe" for a gift set. One MasterBundle
// fans out to many ChannelSKUs (one per marketplace/account combination).
model MasterBundle {
  id String @id @default(cuid())

  // Identity
  name          String
  internal_slug String          @unique
  brand         String // "Salutem Vita" | "Starfit"
  category      String // ProductCategory

  // Composition
  composition_type String // CompositionType
  pack_count       Int
  total_weight_oz  Float?
  total_weight_lb  Float?

  // Pricing (in cents). cost_breakdown holds the un-summed breakdown:
  //   { goods_cents, packaging_cents, sourcing_overhead_cents }
  cost_breakdown        String // JSON
  estimated_cost_cents  Int
  suggested_price_cents Int

  // Packaging spec — { cooler_size, gel_packs_qty, outer_box, ... }
  packaging_spec String // JSON

  // Master images (default across all channels)
  main_image_url        String
  secondary_images      String // JSON array of URLs
  image_generation_meta String? // JSON

  // Lifecycle
  lifecycle_status String @default("DRAFT") // LifecycleState

  // Relations
  components            BundleComponent[]
  channel_skus          ChannelSKU[]
  lifecycle_logs        ListingLifecycleLog[]
  generation_job_id     String?               @unique
  generation_job        GenerationJob?        @relation(fields: [generation_job_id], references: [id])
  research_pool_seed_id String?
  research_pool_seed    ResearchPool?         @relation(fields: [research_pool_seed_id], references: [id])

  // Audit
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt
  created_by_user_id String?

  @@index([brand])
  @@index([category])
  @@index([lifecycle_status])
  @@index([created_at])
}

// BundleComponent — one input product inside a MasterBundle (e.g. "Jimmy
// Dean Sausage, Egg & Cheese × 12"). A MasterBundle typically has 1–5.
model BundleComponent {
  id               String       @id @default(cuid())
  master_bundle_id String
  master_bundle    MasterBundle @relation(fields: [master_bundle_id], references: [id], onDelete: Cascade)

  // Product identity
  product_name       String
  manufacturer_brand String
  manufacturer_upc   String?
  flavor             String?
  variant            String?

  // Quantity & weight
  qty             Int
  unit_weight_oz  Float?
  unit_weight_lb  Float?

  // Cost & sourcing
  unit_price_cents Int
  source_store_id  String?
  source_store     StoreRegistry? @relation(fields: [source_store_id], references: [id])
  source_url       String?

  // Compliance metadata
  ingredients     String?
  allergens       String? // JSON array
  storage_temp    String? // "Frozen" | "Refrigerated" | "Shelf-stable"
  expiration_days Int?

  // Donor image pool (used in Stage 5 image gen)
  donor_image_urls String // JSON array

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([master_bundle_id])
  @@index([manufacturer_brand])
}

// ChannelSKU — one listing on one marketplace under one brand account.
// A MasterBundle typically has 5–9 ChannelSKUs (one per active channel).
model ChannelSKU {
  id               String       @id @default(cuid())
  master_bundle_id String
  master_bundle    MasterBundle @relation(fields: [master_bundle_id], references: [id], onDelete: Cascade)

  // Channel binding
  channel          String // SalesChannel
  brand_account_id String?
  brand_account    BrandAccount? @relation(fields: [brand_account_id], references: [id])

  // Identity
  sku          String   @unique // XX-XXXX-XXXX
  upc          String   @unique
  upc_pool_id  String?  @unique
  upc_pool     UPCPool? @relation(fields: [upc_pool_id], references: [id])

  // Marketplace IDs (populated after publication)
  asin              String?
  walmart_item_id   String?
  ebay_item_id      String?
  tiktok_product_id String?

  // Content (adapted per channel)
  title         String
  bullets       String // JSON array of 5 strings
  description   String
  search_terms  String?
  attributes    String // JSON object

  // Category placement
  channel_category    String?
  channel_browse_node String?

  // Pricing
  price_cents          Int
  business_price_cents Int?

  // Lifecycle
  lifecycle_status String @default("DRAFT") // LifecycleState

  // Publication tracking
  submitted_at  DateTime?
  processing_at DateTime?
  live_at       DateTime?
  live_url      String?
  last_error_at DateTime?
  errors        String? // JSON array

  // Sales tracking
  units_sold_30d    Int? @default(0)
  revenue_30d_cents Int? @default(0)

  // Relations
  lifecycle_logs ListingLifecycleLog[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([master_bundle_id])
  @@index([channel])
  @@index([lifecycle_status])
  @@index([asin])
  @@index([walmart_item_id])
}

// ResearchPool — products discovered by Stage 2 (Research). One row per
// scraped product; used as a candidate pool when drafting a bundle.
model ResearchPool {
  id String @id @default(cuid())

  // Search context
  research_query    String
  generation_job_id String?
  generation_job    GenerationJob? @relation(fields: [generation_job_id], references: [id])

  // Product data
  product_name String
  brand        String
  manufacturer String?
  upc          String?

  // Variations
  flavors    String? // JSON array
  pack_sizes String? // JSON array
  weight_oz  Float?
  weight_lb  Float?

  // Composition
  ingredients     String?
  allergens       String? // JSON array
  nutrition       String? // JSON
  storage_temp    String?
  expiration_days Int?

  // Reference images
  reference_image_urls String // JSON array

  // Pricing & sourcing
  avg_price_cents    Int?
  source_store_id    String?
  source_store       StoreRegistry? @relation(fields: [source_store_id], references: [id])
  source_url         String?
  last_seen_in_stock DateTime?

  // Quality scoring
  freshness_score Float?

  // Back-relation: bundles seeded from this product
  master_bundles MasterBundle[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([brand])
  @@index([generation_job_id])
  @@index([last_seen_in_stock])
}

// BundleDraft — work-in-progress bundle (Stages 3–6 of pipeline). After
// approval it converts to a MasterBundle + ChannelSKU set.
model BundleDraft {
  id                String        @id @default(cuid())
  generation_job_id String
  generation_job    GenerationJob @relation(fields: [generation_job_id], references: [id], onDelete: Cascade)

  // Draft state
  draft_name       String
  brand            String
  category         String // ProductCategory
  composition_type String // CompositionType
  pack_count       Int

  // Composition snapshot (selected components from ResearchPool)
  draft_components String // JSON array

  // Generated content (Stage 4)
  draft_title        String?
  draft_bullets      String? // JSON array
  draft_description  String?
  draft_search_terms String?

  // Generated images (Stage 5)
  draft_main_image_url   String?
  draft_secondary_images String? // JSON array

  // Cost estimate
  draft_cost_cents            Int?
  draft_suggested_price_cents Int?

  // Status
  status          String  @default("VARIATION_SELECTED") // LifecycleState
  approval_notes  String?

  // Selected channels for distribution
  target_channels String // JSON array

  // After approval — link to created MasterBundle
  master_bundle_id String? @unique

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([generation_job_id])
  @@index([status])
}

// StoreRegistry — pre-seeded registry of 37 sourcing stores (Walmart, BJ's,
// Target, Publix, Sam's, Costco, ALDI, Whole Foods, Trader Joe's, Fresh
// Market, Winn-Dixie). See docs/BUNDLE_FACTORY_SOURCING_MAP.md.
model StoreRegistry {
  id         String @id // e.g. "walmart_sc_us19"
  name       String
  chain      String
  store_type String // StoreType
  tier       String // StoreTier

  // Location
  address          String
  latitude         Float
  longitude        Float
  distance_mi      Float // from 1162 Kapp Dr
  google_place_id  String?
  google_maps_url  String?

  // Operational
  phone       String?
  hours_text  String?
  hours_json  String? // JSON
  website_url String?

  // Delivery
  delivery_program    String?
  delivery_cost_cents Int     @default(0)
  delivery_notes      String?

  // Status
  is_active              Boolean   @default(true)
  is_membership_required Boolean   @default(false)
  membership_active      Boolean   @default(false)
  membership_renewal     DateTime?

  // Default priority used as seed when wiring SKUStorePriority elsewhere
  default_priority Int

  // Operational metadata
  last_validated_at DateTime?
  notes             String?

  // Relations
  components_sourced BundleComponent[]
  research_pool      ResearchPool[]
  fallback_from      ProductSourceFallback[] @relation("PrimarySource")
  fallback_to        ProductSourceFallback[] @relation("FallbackSource")
  stock_checks       StockCheckLog[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([chain])
  @@index([tier])
  @@index([is_active])
  @@index([distance_mi])
}

// ProductSourceFallback — substitute graph: when primary store is OOS for
// a manufacturer UPC, try these fallbacks in priority order.
model ProductSourceFallback {
  id String @id @default(cuid())

  manufacturer_upc String
  product_name     String

  primary_store_id String
  primary_store    StoreRegistry @relation("PrimarySource", fields: [primary_store_id], references: [id])

  fallback_store_id String
  fallback_store    StoreRegistry @relation("FallbackSource", fields: [fallback_store_id], references: [id])

  fallback_priority Int

  // Stats — populated by the sourcing pipeline as it runs
  primary_oos_count     Int @default(0)
  fallback_used_count   Int @default(0)
  fallback_failed_count Int @default(0)

  notes String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([manufacturer_upc, primary_store_id, fallback_store_id])
  @@index([manufacturer_upc])
}

// StockCheckLog — audit of stock-availability checks (pre-publication
// re-check, quarterly sourcing validation, OOS pattern analytics).
model StockCheckLog {
  id String @id @default(cuid())

  store_id String
  store    StoreRegistry @relation(fields: [store_id], references: [id])

  manufacturer_upc String?
  product_name     String?

  in_stock     Boolean
  price_cents  Int?
  source_url   String?
  raw_response String? // JSON

  checked_at   DateTime @default(now())
  check_method String // "scraper" | "manual" | "api"

  @@index([store_id])
  @@index([manufacturer_upc])
  @@index([checked_at])
}

// UPCPool — pool of UPC codes Vladimir owns (prefixes 742259/789232/617261).
// Pre-seeded from the Active Listings Report; replenished manually later.
model UPCPool {
  id            String  @id @default(cuid())
  upc           String  @unique
  upc_prefix    String
  gs1_validated Boolean @default(false)
  gs1_owner     String?

  status String @default("AVAILABLE") // UPCStatus

  // If ASSIGNED — which ChannelSKU owns this UPC (1:1)
  assigned_to_id String?     @unique
  assigned_to    ChannelSKU?

  // If RESERVED — which BundleDraft holds it (with TTL)
  reserved_for_id String?
  reserved_at     DateTime?
  reserved_until  DateTime?

  acquired_from String?
  acquired_at   DateTime?
  notes         String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([status])
  @@index([upc_prefix])
  @@index([gs1_validated])
}

// GTINExemption — per-brand × channel × category exemption status.
// Vladimir submits applications for Salutem Vita / Starfit; this tracks them.
model GTINExemption {
  id       String @id @default(cuid())
  brand    String // "Salutem Vita" | "Starfit"
  channel  String // SalesChannel
  category String // ProductCategory

  status String @default("NOT_REQUESTED") // GTINExemptionStatus

  application_date    DateTime?
  approval_date       DateTime?
  denial_reason       String?
  application_pdf_url String?
  reference_id        String? // Amazon case ID

  notes String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([brand, channel, category])
  @@index([status])
}

// BrandAccount — mapping of brand × channel × account (brand owner vs
// authorized seller). E.g. Salutem Vita on AMAZON_SALUTEM is the brand
// owner; the same brand on AMAZON_PERSONAL is authorized seller.
model BrandAccount {
  id                   String  @id @default(cuid())
  brand                String
  channel              String // SalesChannel
  is_brand_owner       Boolean
  is_authorized_seller Boolean
  selling_partner_id   String? // SP-API merchant ID / Walmart seller ID

  is_active Boolean @default(true)
  notes     String?

  channel_skus ChannelSKU[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([brand, channel])
  @@index([brand])
  @@index([channel])
}

// GenerationJob — one execution of the pipeline (brief → drafts → bundles).
model GenerationJob {
  id String @id @default(cuid())

  // Brief input (Stage 1) — full form from the user
  brief String // JSON

  // Status
  current_stage String @default("BRIEF") // PipelineStage
  status        String @default("PENDING") // StageStatus

  // Stats
  bundles_target    Int
  bundles_generated Int @default(0)
  bundles_approved  Int @default(0)
  bundles_published Int @default(0)
  bundles_error     Int @default(0)

  // Resource consumption
  openai_tokens_used Int @default(0)
  perplexity_queries Int @default(0)
  images_generated   Int @default(0)
  cost_cents         Int @default(0)

  user_id String?
  notes   String?

  // Relations
  stages         GenerationStage[]
  research_pool  ResearchPool[]
  bundle_drafts  BundleDraft[]
  master_bundles MasterBundle[]

  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  completed_at DateTime?

  @@index([status])
  @@index([current_stage])
}

// GenerationStage — per-stage execution log for a GenerationJob.
model GenerationStage {
  id                String        @id @default(cuid())
  generation_job_id String
  generation_job    GenerationJob @relation(fields: [generation_job_id], references: [id], onDelete: Cascade)

  stage  String // PipelineStage
  status String @default("PENDING") // StageStatus

  started_at   DateTime?
  completed_at DateTime?
  duration_ms  Int?

  input_snapshot  String? // JSON
  output_snapshot String? // JSON
  error           String?

  @@index([generation_job_id])
  @@index([stage])
}

// MarketplaceRule — DB cache of the Marketplace Rules KB. The Markdown
// files in docs/marketplace-rules/ remain the source of truth; this table
// is for hot lookup at validation/generation time.
model MarketplaceRule {
  id String @id @default(cuid())

  channel    String // SalesChannel
  category   String? // ProductCategory (null = global to channel)
  rule_key   String
  rule_value String // JSON (scalar or object)

  // Provenance
  source_doc_path String
  source_url      String?
  scraped_at      DateTime?
  validated_at    DateTime?
  is_current      Boolean   @default(true)

  notes String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([channel, category, rule_key])
  @@index([channel])
  @@index([rule_key])
  @@index([is_current])
}

// ErrorPattern — accumulator of marketplace errors and their fix strategies
// (Stage 6 learning loop).
model ErrorPattern {
  id String @id @default(cuid())

  channel               String // SalesChannel
  error_category        String // ErrorCategory
  error_code            String
  error_message_pattern String

  // Fix strategy
  fix_strategy     String // "AUTO_FIX_TITLE_TRUNCATE" | "AUTO_FIX_ADD_ATTRIBUTE" | "ESCALATE"
  fix_handler_name String?

  // Stats
  occurrences       Int       @default(0)
  auto_fix_success  Int       @default(0)
  auto_fix_failure  Int       @default(0)
  last_seen         DateTime?

  // Documentation
  description    String?
  example_input  String? // JSON
  example_output String? // JSON

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([channel])
  @@index([error_category])
  @@index([error_code])
}

// ListingLifecycleLog — audit trail for MasterBundle and ChannelSKU
// lifecycle_status transitions.
model ListingLifecycleLog {
  id String @id @default(cuid())

  // What changed
  entity_type String // "MasterBundle" | "ChannelSKU"
  entity_id   String

  master_bundle_id String?
  master_bundle    MasterBundle? @relation(fields: [master_bundle_id], references: [id], onDelete: Cascade)

  channel_sku_id String?
  channel_sku    ChannelSKU? @relation(fields: [channel_sku_id], references: [id], onDelete: Cascade)

  // Transition
  from_status String? // LifecycleState
  to_status   String // LifecycleState

  // Context
  trigger String // "user_approve" | "auto_publish" | "marketplace_error" | "sourcing_oos" | ...
  details String? // JSON
  user_id String?

  created_at DateTime @default(now())

  @@index([entity_type, entity_id])
  @@index([master_bundle_id])
  @@index([channel_sku_id])
  @@index([created_at])
}

// ============================================================================
// PHASE 2.0a — Listing Audit Tool
// Scans existing active listings across 5 Amazon accounts, scores risk of
// foreign-brand violations (like the 2026-05-17 Retailer Distributor block),
// and tracks remediation through Bundle Factory's content/image pipelines.
// ============================================================================

model ListingAuditScan {
  id           String @id @default(cuid())
  initiated_by String // 'vladimir' | 'system_cron'

  status String @default("pending") // 'pending' | 'running' | 'completed' | 'failed'

  started_at   DateTime  @default(now())
  completed_at DateTime?

  accounts_scanned String // JSON array of account keys

  total_listings  Int @default(0)
  blocked_count   Int @default(0)
  warning_count   Int @default(0)
  low_risk_count  Int @default(0)
  compliant_count Int @default(0)

  error_message String?

  audit_results ListingAuditResult[]

  @@index([initiated_by, started_at])
  @@index([status])
}

model ListingAuditResult {
  id      String @id @default(cuid())
  scan_id String

  asin    String
  sku     String?
  account String // 'SALUTEM' | 'PERSONAL' | 'AMZCOM' | 'SIRIUS' | 'RETAILER'

  title                String
  brand                String
  browse_node          String?
  main_image_url       String?
  original_bullets     String // JSON array
  original_description String @default("")

  risk_score    Int    @default(0)
  risk_category String @default("COMPLIANT") // 'BLOCKED' | 'WARNING' | 'LOW_RISK' | 'COMPLIANT'
  risk_reasons  String @default("[]") // JSON array

  detected_brands   String? // JSON array
  detected_logos    String? // JSON array (from Vision check)
  vision_cost_cents Int     @default(0)

  remediation_status String @default("PENDING") // 'PENDING' | 'REGENERATING' | 'UPDATED' | 'SKIPPED' | 'FAILED' | 'MANUAL_REVIEW'

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  scan ListingAuditScan @relation(fields: [scan_id], references: [id], onDelete: Cascade)
  // 1:1 back-reference — actual FK column (audit_result_id) lives on
  // ListingRemediation. We query by audit_result_id from there.
  remediation ListingRemediation?

  @@index([scan_id, risk_category])
  @@index([asin])
  @@index([account, risk_category])
  @@index([remediation_status])
}

model ListingRemediation {
  id              String @id @default(cuid())
  audit_result_id String @unique

  status String @default("pending") // 'pending' | 'generating' | 'validated' | 'updating' | 'completed' | 'failed' | 'manual_review'

  original_title       String
  new_title            String?
  original_bullets     String // JSON array
  new_bullets          String? // JSON array
  original_description String
  new_description      String?
  original_image_url   String?
  new_image_url        String?

  ai_cost_cents Int @default(0)

  sp_api_response String? // JSON
  sp_api_error    String?

  started_at   DateTime  @default(now())
  completed_at DateTime?

  audit_result ListingAuditResult @relation(fields: [audit_result_id], references: [id], onDelete: Cascade)

  @@index([status])
}

// Permanent blocklist seeded from the 2026-05-17 incident (5 ASINs blocked
// by Amazon for Trademark Logo Misuse under Salutem Vita). New incidents
// can be appended here so risk-scoring picks them up automatically.
model BrandConflict {
  id      String  @id @default(cuid())
  asin    String?
  account String?

  foreign_brand    String
  product_keywords String // JSON array

  incident_date DateTime
  incident_type String // 'trademark_logo_misuse' | 'ip_complaint'
  amazon_action String? // 'asin_block' | 'account_suspension'

  notes String?

  status      String    @default("active")
  resolved_at DateTime?

  created_at DateTime @default(now())

  @@index([foreign_brand])
  @@index([asin])
  @@index([status])
}
