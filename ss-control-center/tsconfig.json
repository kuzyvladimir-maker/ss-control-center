{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "scripts",
    "**/__tests__/**",
    "src/lib/walmart/item-report-request-reconciliation.ts",
    "src/lib/walmart/item-report-reissue-executor-v2.ts",
    "src/lib/walmart/item-report-reissue-evidence.ts",
    "src/lib/walmart/listing-integrity-remediation-*.ts",
    "src/lib/walmart/listing-integrity-single-pipeline.ts",
    "_*.ts",
    "_*.mts",
    "_*.mjs",
    "**/_*.ts",
    "**/_*.mts",
    "**/_*.mjs"
  ]
}
