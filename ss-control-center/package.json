{
  "name": "ss-control-center",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0 <26"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test:product-truth-economics": "node --import tsx --test src/lib/economics/__tests__/product-truth-profit-guard.test.ts",
    "walmart:new-sku": "node --import tsx scripts/walmart-new-sku-engine.ts",
    "walmart:new-sku:owner": "node --import tsx scripts/walmart-new-sku-owner.ts",
    "walmart:new-sku:owner-signer": "node scripts/walmart-new-sku-owner-signer.mjs",
    "walmart:new-sku:release": "node --import tsx scripts/walmart-new-sku-release.ts",
    "walmart:new-sku:release:freeze": "node --import tsx scripts/walmart-new-sku-release-freeze.ts",
    "walmart:new-sku:schema": "node --import tsx scripts/walmart-new-sku-schema-activation.ts",
    "walmart:new-sku:catalog": "node --import tsx scripts/walmart-new-sku-catalog-activation.ts",
    "walmart-listing-freeze": "node --experimental-strip-types scripts/freeze-walmart-listing-integrity-bundle.mjs",
    "walmart-listing-engine": "node --experimental-strip-types scripts/walmart-listing-integrity-engine.mjs",
    "walmart-listing-observer": "node --experimental-strip-types scripts/walmart-listing-integrity-observer.mjs",
    "walmart-listing-catalog": "node --env-file=.env --experimental-strip-types scripts/walmart-listing-integrity-catalog.mjs",
    "walmart-listing-triage": "node --experimental-strip-types scripts/walmart-listing-integrity-triage.mjs",
    "walmart-listing-triage-observer": "node --experimental-strip-types scripts/walmart-listing-integrity-triage-observer.mjs",
    "walmart:listing-repair": "node scripts/verify-and-run-walmart-listing-repair.mjs",
    "walmart:item-v6-absence-probe": "node --env-file=.env --experimental-strip-types scripts/capture-walmart-item-v6-absence-probe.mjs",
    "product-truth": "node --import tsx scripts/product-truth-runner.ts",
    "product-truth:census": "node --import tsx scripts/build-phase1-connected-store-census.ts",
    "product-truth:manifest": "node --import tsx scripts/build-phase1-scope-manifest.ts",
    "product-truth:migrations": "node --import tsx scripts/product-truth-migration-plan.ts",
    "channelmax:worker": "node --import tsx scripts/channelmax-browser-worker.ts",
    "channelmax:preflight-uncrustables": "node --import tsx scripts/preflight-uncrustables-channelmax-mutation.ts",
    "test:channelmax-worker": "node --import tsx --test src/lib/channelmax-agent/__tests__/browser-worker.test.ts",
    "test:channelmax-preflight": "node --import tsx --test src/lib/channelmax-agent/__tests__/uncrustables-mutation-preflight.test.ts",
    "test:product-truth-certification": "node --import tsx --test src/lib/sourcing/__tests__/*.test.ts src/lib/sourcing/__tests__/*.test.mjs src/lib/economics/__tests__/product-truth-*.test.ts",
    "test:product-truth-safety": "npm run test:product-truth-certification",
    "test:channelmax-canary": "node --import tsx --test src/lib/channelmax-agent/__tests__/uncrustables-same-model-canary.test.ts",
    "test:channelmax-canary-adapter": "node --import tsx --test src/lib/channelmax-agent/__tests__/uncrustables-same-model-cdp-adapter.test.ts",
    "test:channelmax-canary-artifacts": "node --import tsx --test src/lib/channelmax-agent/__tests__/uncrustables-canary-artifact-route.test.ts",
    "models:check": "npx tsx scripts/check-model-updates.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@aws-sdk/client-s3": "^3.1049.0",
    "@base-ui/react": "^1.3.0",
    "@libsql/client": "^0.17.2",
    "@prisma/adapter-libsql": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "ajv": "^6.14.0",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "date-holidays": "^3.29.0",
    "googleapis": "^171.4.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "openai": "^6.34.0",
    "pdf-lib": "^1.17.1",
    "prisma": "^7.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.2",
    "sharp": "^0.35.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
